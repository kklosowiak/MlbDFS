# OMEGA Engine Git Exclusion
# Critical: Protect API Keys
.env

# Runtime
__pycache__/
*.pyc

# Data & Snapshots
data/snapshot_*.json
data/statcast_cache.json
data/statcast_xwoba_meta.json
data/expert_weather_cache.json
data/probable_pitchers.json
data/opening_lines.json
data/opening_lines_*.json
data/consensus_*_live.json
data/platoon_cache.json
data/bullpen_fatigue_cache.json

# Local Dev
.vscode/
.idea/
.gemini/
logs/
scratch/*
!scratch/passive_tracker/

# Ignore large daily files that regenerate each night
scratch/passive_tracker/slates/*.json
scratch/passive_tracker/actuals/*.json
scratch/passive_tracker/snapshots/all_teams_*.csv
scratch/passive_tracker/snapshots/all_pitchers_*.csv
scratch/passive_tracker/snapshots/all_hitters_*.csv
scratch/passive_tracker/snapshots/intraday_deltas_*.csv
scratch/passive_tracker/**/*.txt
scratch/passive_tracker/capture_log.txt
scratch/passive_tracker/actuals_log.txt
scratch/passive_tracker/error_log.txt
!scratch/passive_tracker/digests/*.txt


# Analysis Results
reports/latest_results.json
reports/dashboard.html
reports/learning_feedback.*
reports/archive/
